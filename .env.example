# InstaFlow AI - frontend environment contract
# Copy to `.env.local` for local development.

# App
VITE_APP_NAME=InstaFlow AI
VITE_APP_URL=http://localhost:8081

# Supabase (safe in frontend when using anon/public key + RLS)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Platform integrations surfaced in the frontend
VITE_META_APP_ID=your-meta-app-id
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
VITE_SENTRY_DSN=

# Server-side / edge-function secrets stay out of the frontend env file:
# SUPABASE_SERVICE_ROLE_KEY=
# META_APP_SECRET=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_AI_API_KEY=
# STRIPE_SECRET_KEY=
# RESEND_API_KEY=
